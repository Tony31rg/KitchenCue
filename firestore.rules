rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAllowedRole(role) {
      return role in ['waiter', 'kitchen'];
    }

    function isValidUserCreate() {
      return request.resource.data.keys().hasOnly([
        'name',
        'role',
        'active',
        'createdAt',
        'updatedAt',
        'mustResetPin',
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.active is bool
      && request.resource.data.mustResetPin is bool
      && isAllowedRole(request.resource.data.role);
    }

    function isValidUserUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name',
        'active',
        'updatedAt',
        'mustResetPin',
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.active is bool
      && request.resource.data.mustResetPin is bool
      && request.resource.data.role == resource.data.role;
    }

    // Staff profile: each user can only read own role/profile document.
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid) && isValidUserCreate();
      allow update: if isSelf(uid) && isValidUserUpdate();
      allow delete: if false;
    }

    // Staff auth and secret documents are only accessed through Cloud Functions.
    match /staff/{document=**} {
      allow read, write: if false;
    }

    match /staffSecrets/{document=**} {
      allow read, write: if false;
    }

    match /staffNameIndex/{document=**} {
      allow read, write: if false;
    }

    match /staffSessions/{document=**} {
      allow read, write: if false;
    }

    // Default deny: explicitly open collections when needed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
